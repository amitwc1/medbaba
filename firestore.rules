rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Only allow users to read/write their own document and subcollections
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // As a best practice, explicitly deny everything else unless specified
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
